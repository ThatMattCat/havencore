# HavenCore configuration.
# Copy this file to .env and fill in the values.
#
# How to read this file:
#   1. REQUIRED — must be set before first boot.
#   2. LOCALE, VOICE, DATABASE — working defaults exist, but most users customize these.
#   3. FEATURE INTEGRATIONS — each section is optional; skip any you don't use.
#   4. AUTONOMY / MCP / MEMORY / OBSERVABILITY — safe defaults; touch only if you know why.
#
# .env changes require `docker compose down && up -d` to take effect.


# ============= REQUIRED =============
# The stack will not work until these three are set.

HOST_IP_ADDRESS="10.0.0.1"                    # LAN IP of the host running the Docker containers
LLM_API_BASE="http://10.0.0.1:8000/v1"        # OpenAI-compatible endpoint the agent calls (vLLM by default). Usually http://<HOST_IP_ADDRESS>:8000/v1.
LLM_API_KEY="1234"                            # Bearer token the agent sends to vLLM; must match vLLM's --api-key.


# ============= LOCALE & IDENTITY =============
# Baked into the system prompt and used for weather, scheduling, and the morning briefing.
# Wrong CURRENT_TIMEZONE will break autonomy cron schedules.

AGENT_NAME="Selene"
CURRENT_LOCATION="Citytonville, OH, USA"
CURRENT_TIMEZONE="America/Chicago"
CURRENT_ZIPCODE="00000"
TZ=${CURRENT_TIMEZONE}                        # Container-local timezone (libc picks this up automatically). Leave as-is.


# ============= VOICE I/O =============
# GPU indices route TTS/STT to a specific card on multi-GPU hosts.
# SRC_LAN and TTS_LANGUAGE must match your spoken language.

TTS_DEVICE="cuda:0"                           # GPU index for text-to-speech (Kokoro)
STT_DEVICE="0"                                # GPU index for speech-to-text (Faster Whisper)
TTS_LANGUAGE="a"                              # Kokoro TTS language code ("a" = English)
TTS_VOICE="af_heart"                          # Kokoro voice id
SRC_LAN="en"                                  # ISO 639-1 code for STT


# ============= DATABASE =============
# Defaults work out of the box. Change POSTGRES_PASSWORD for any exposed deployment.

POSTGRES_DB=havencore
POSTGRES_USER=havencore
POSTGRES_PASSWORD=havencore_password


# ============= Home Assistant (optional) =============
# Leave blank to skip. HA tools will boot in mock mode and return "not configured" errors.

HAOS_URL="https://localhost:8123/api"         # Your Home Assistant URL
HAOS_TOKEN=""                                 # Long-lived Home Assistant access token


# ============= Plex (optional) =============
# Leave blank to skip. Plex tools will boot in mock mode.

PLEX_URL="http://localhost:32400"             # Base URL of your Plex Media Server (no trailing slash)
PLEX_TOKEN=""                                 # X-Plex-Token. Plex web UI > Settings > Account, or from a media item's XML.

# Optional. JSON map from Plex device name -> HA entities used to wake the TV and launch the Plex app before playMedia().
# state_entity is read for current app / power state. adb_entity is the androidtv entity used for adb_command.
# Example:
# PLEX_CLIENT_HA_MAP='{"BRAVIA 4K VH21":{"state_entity":"media_player.living_room_tv_bravia_4k_vh21","adb_entity":"media_player.living_room_bravia_adb"}}'
PLEX_CLIENT_HA_MAP=''


# ============= Music Assistant (optional) =============
# Audio-only playback router for speakers / Chromecasts / Google Homes.
# Schema v28+ requires a long-lived token — mint one in MA web UI at Settings -> Users -> Create long-lived token.
# Leave blank to skip; MA tools will boot in mock mode.

MASS_URL="http://HOME_ASSISTANT_IP:8095"
MASS_TOKEN=""


# ============= External APIs (optional) =============
# Each tool is only registered with the LLM if its key is set.
# Blank key => the tool simply doesn't appear to the agent; no crash.

WEATHER_API_KEY=""                            # From weatherapi.com
BRAVE_SEARCH_API_KEY=""                       # From search.brave.com/api
WOLFRAM_ALPHA_API_KEY=""                      # From developer.wolframalpha.com


# ============= Hugging Face (optional) =============
# Only needed if you pull gated models (e.g. Llama family).

HF_HUB_TOKEN=""                               # Huggingface token
HUGGING_FACE_HUB_TOKEN=${HF_HUB_TOKEN}        # Different tools use different names, c'est la vie. Leave as-is.


# ============= Signal Messenger (optional) =============
# Outbound notifications via signal-cli-rest-api (compose service: signal-api).
# One-time setup: link this container to your Signal account by scanning a QR
# code — see docs/services/agent/tools/general.md#signal-one-time-setup.
# Leave SIGNAL_PHONE_NUMBER blank to skip; the send_signal_message tool won't be registered.

SIGNAL_API_URL="http://signal-api:8080"       # internal Docker hostname, never exposed to internet
SIGNAL_PHONE_NUMBER=""                        # your Signal account number, E.164 format (e.g. +15551234567)
SIGNAL_DEFAULT_RECIPIENT=""                   # where to send; leave empty to send to SIGNAL_PHONE_NUMBER (Note to Self)


# ============= Autonomy Engine =============
# Proactive behaviors (morning briefing, anomaly sweeps, reactive triggers).
# Safe defaults below; flip AUTONOMY_ENABLED to false to disable the whole engine.

# --- core / scheduling ---
AUTONOMY_ENABLED=true
AUTONOMY_DISPATCH_INTERVAL_SECONDS=30
AUTONOMY_BRIEFING_CRON="0 8 * * *"
AUTONOMY_ANOMALY_CRON="*/15 * * * *"
AUTONOMY_ANOMALY_COOLDOWN_MIN=30
AUTONOMY_MAX_RUNS_PER_HOUR=20
AUTONOMY_TURN_TIMEOUT_SEC=60
AUTONOMY_ANOMALY_WATCH_DOMAINS="binary_sensor,lock,cover"

# --- notifications ---
AUTONOMY_BRIEFING_NOTIFY_TO=""                    # Signal recipient for the morning briefing (Signal number; empty = SIGNAL_DEFAULT_RECIPIENT)
AUTONOMY_HA_NOTIFY_TARGET=""                      # e.g. notify.mobile_app_pixel_8 (no leading "notify/")
AUTONOMY_BRIEFING_CAMERA_ENTITIES=""              # comma-separated camera entity_ids for overnight summary

# --- v3 reactive (webhooks / MQTT / quiet hours) ---
AUTONOMY_WEBHOOK_ENABLED=false                    # POST /api/autonomy/webhook/{name} intake
AUTONOMY_MQTT_ENABLED=false                       # live MQTT subscriber against the existing broker
AUTONOMY_MQTT_CLIENT_ID="selene-autonomy"
AUTONOMY_MQTT_RECONNECT_MAX_SEC=60
AUTONOMY_DEFAULT_QUIET_START=""                   # "22:00" (empty => no default quiet hours)
AUTONOMY_DEFAULT_QUIET_END=""                     # "07:00"
AUTONOMY_DEFAULT_QUIET_POLICY="defer"             # "defer" | "drop"
AUTONOMY_DEFAULT_EVENT_RATE_LIMIT="10/min"        # per-item default burst limit for event triggers

# --- v4 voice + actuation ---
AUTONOMY_SPEAKER_DEFAULT_DEVICE=""                # default MA player name for speaker-channel notifications
AUTONOMY_SPEAKER_DEFAULT_VOICE="af_heart"         # default Kokoro voice for SpeakerNotifier
AUTONOMY_SPEAKER_DEFAULT_VOLUME="0.5"             # 0.0-1.0 volume for announcements
AUTONOMY_TTS_AUDIO_TTL_SEC=600                    # lifetime of signed audio URLs served at /api/tts/audio/{token}.mp3
AUTONOMY_ACT_ENABLED=false                        # kill-switch for the v4 act tier; flip to true once confident
AUTONOMY_ACT_DEFAULT_CONFIRMATION_TIMEOUT_SEC=300 # default window for a user to approve/deny an act run
AGENT_BASE_URL=""                                 # public URL used in Signal confirmation links (e.g. http://10.0.0.1:6002); empty => dashboard link omitted
AGENT_INTERNAL_BASE_URL="http://agent:6002"       # base URL Music Assistant uses to fetch announcement audio. If MA runs outside this compose stack, set to http://<docker-host-LAN-ip>:6002 so MA can reach it.


# ============= MCP Configuration =============
# MCP is the preferred tool surface; disable only for legacy fallback.

MCP_ENABLED=true
MCP_PREFER_OVER_LEGACY="true"

MCP_SERVERS='[
{
  "name": "plex",
  "command": "python",
  "args": ["-m", "selene_agent.modules.mcp_plex_tools"],
  "enabled": true
},
{
  "name": "music_assistant",
  "command": "python",
  "args": ["-m", "selene_agent.modules.mcp_music_assistant_tools"],
  "enabled": true
},
{
  "name": "general_tools",
  "command": "python",
  "args": ["-m", "selene_agent.modules.mcp_general_tools"],
  "enabled": true
},
{
  "name": "mcp_server_fetch",
  "command": "/usr/bin/python",
  "args": ["-m", "mcp_server_fetch"],
  "enabled": true
}]'


# ============= Agent Runtime Tuning =============
# Seconds of inactivity before the session pool summarizes the conversation
# and resets it in place (same session_id, compact recap preserved). Clients
# may override per-session via the `X-Idle-Timeout` REST header or the
# `idle_timeout` field on a WebSocket `{"type":"session", ...}` frame.
CONVERSATION_TIMEOUT=90
CONVERSATION_TIMEOUT_MIN=10
CONVERSATION_TIMEOUT_MAX=3600

# When an idle session expires, the agent runs a one-shot LLM call to
# summarize the prior turns before resetting. These tune that summary call.
SESSION_SUMMARY_MAX_TOKENS=400
SESSION_SUMMARY_TAIL_EXCHANGES=2
SESSION_SUMMARY_LLM_TIMEOUT_SEC=15

# Cap on tool-result text before it is handed back to the LLM
TOOL_RESULT_MAX_CHARS=8000


# ============= Advanced — Memory Tuning =============
# You almost certainly don't need to touch these; they tune the v2 memory consolidation pipeline.

AUTONOMY_MEMORY_REVIEW_CRON="0 3 * * *"
AUTONOMY_MEMORY_MAX_SCAN=5000
AUTONOMY_MEMORY_LLM_CALL_CAP=20

MEMORY_HALF_LIFE_DAYS=60
MEMORY_ACCESS_COEF=0.5

MEMORY_HDBSCAN_MIN_CLUSTER_SIZE=5
MEMORY_HDBSCAN_MIN_SAMPLES=3

MEMORY_L4_MIN_IMPORTANCE=4
MEMORY_L4_MIN_AGE_DAYS=14
MEMORY_L4_MIN_ACCESS_COUNT=3

MEMORY_L2_PRUNE_AGE_DAYS=180
MEMORY_L2_PRUNE_IMPORTANCE_THRESHOLD=0.5

MEMORY_L3_RANK_BOOST=1.2
MEMORY_L4_MAX_ENTRIES=20
MEMORY_L4_WARN_TOKENS=1500


# ============= Observability =============

DEBUG_LOGGING=0                                                 # 0 = off, 1 = on
LOKI_URL='http://localhost:3100/loki/api/v1/push'
